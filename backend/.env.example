# Copy to backend/.env on the server (backend/.env is not committed to git).
# On EC2 after git pull:
#   bash scripts/apply-ec2-env.sh

DEBUG=False
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me

DB_NAME=bingo_db
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379

ALLOWED_HOSTS=16.16.200.57,localhost,127.0.0.1

TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Required: URL opened by the Telegram bot "Play" button (must be HTTPS for Mini App)
TELEGRAM_WEB_APP_URL=http://16.16.200.57
